# Example environment variables (DO NOT COMMIT .env)
# Copy this file to `.env` and fill in the real values.

# Gemini / Google Generative Language API
GEMINI_API_KEY=your_real_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MEMORY_TTL_MINUTES=5

# Database (Postgres)
# When running locally with Docker Compose the defaults in docker-compose.override.yml are used.
SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:5432/chat_db
SPRING_DATASOURCE_USERNAME=user
SPRING_DATASOURCE_PASSWORD=password

# Redis (default)
SPRING_REDIS_HOST=127.0.0.1
SPRING_REDIS_PORT=6379
